# ---------------------------------------------------------------------------
# Foundry Workshop · .env (one-time setup)
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in 讲师下发的值. 整个 workshop (Lab 0/1/2/3/4)
# 所有脚本 + azd deploy postdeploy hook 都从这里读凭据.
# Lab 1 会把部署所需字段同步到当前 azd env, 供 azd variable substitution 使用.
#
# 两类凭据互不重叠, 都必填:
#   - SP (AZURE_*): 用于 azd auth login + azd deploy + 自动赋权 hook.
#                   不用 az login, 不弹窗, azd auth login 不需要 --service-principal 参数.
#   - Foundry api key: 用于调 hosted agent (chat / invoke / sanity).
#                       本地 Lab 2 的 FoundryChatClient 走 SP 环境变量 / DefaultAzureCredential.
# ---------------------------------------------------------------------------


# === 学员服务主体凭据 (讲师下发) — 部署用 =====================================
# 给 azd 用 (Lab 0 登录 / Lab 1+3 部署 / postdeploy 自动赋 AcrPull + Azure AI User)
AZURE_TENANT_ID=<tenant guid>
AZURE_CLIENT_ID=<sp appId>
AZURE_CLIENT_SECRET=<sp secret>
AZURE_SUBSCRIPTION_ID=<sub guid>
AZURE_LOCATION=eastus2


# === 共享 Foundry 项目 (讲师下发) ===========================================
# Project endpoint 形如 https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>

# Project ARM resource ID (azd deploy 要求), 形如
# /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<account>/projects/<project>
AZURE_AI_PROJECT_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<account>/projects/<project>

# 模型 deployment 名 (讲师指定)
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.4-mini

# Foundry account API key (讲师下发) — 用于本地 chat UI / invoke / sanity-check.
# header: api-key. 不过期, 不依赖 AAD. 单一稳健路径.
FOUNDRY_API_KEY=<foundry account key>


# === 共享 ACR (讲师下发) ====================================================
# azd deploy 通过 ACR remote build 推镜像到这里
AZURE_CONTAINER_REGISTRY_NAME=cr...
AZURE_CONTAINER_REGISTRY_ENDPOINT=cr....azurecr.io


# === 学员后缀 (讲师分配) ====================================================
# 决定 hosted agent 名 = research-agent-<STUDENT_SUFFIX>
STUDENT_SUFFIX=stu01
